# Copy this to .env and fill in your values

# --- Ollama Setup (required for local LLM) ---
# 1. Install Ollama: https://ollama.com/download
#    Linux: curl -fsSL https://ollama.com/install.sh | sh
# 2. Pull the default model: ollama pull qwen2.5:14b
#    Alternatives (edit opencode.json "model" to switch):
#      ollama pull qwen2.5:7b      (~4 GB VRAM, fast)
#      ollama pull qwen2.5:32b     (~20 GB VRAM, best quality)
#      ollama pull llama3.1:8b     (~5 GB VRAM, alternative)
# 3. The app auto-starts Ollama on launch (no manual start needed).

OPENCODE_URL=http://localhost:4096

# Cloud API keys — only needed if switching to a cloud model in opencode.json
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# SQLite database path (defaults to cursor_urban.db in backend dir)
CURSOR_URBAN_DB=cursor_urban.db

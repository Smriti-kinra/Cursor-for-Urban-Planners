# Copy this to .env and fill in your values

OPENCODE_URL=http://localhost:4096

# Required — default model is openai/gpt-5-mini
OPENAI_API_KEY=

# Claude and Gemini are currently locked in the UI; keys not required yet.
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# SQLite database path (defaults to cursor_urban.db in backend dir)
CURSOR_URBAN_DB=cursor_urban.db

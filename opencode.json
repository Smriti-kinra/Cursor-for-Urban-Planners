{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5-mini",
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5-mini": { "name": "GPT-5 Mini" }
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    }
  },
  "tools": {
    "read": false,
    "write": false,
    "bash": false,
    "edit": false,
    "glob": false,
    "grep": false,
    "patch": false,
    "todoread": false,
    "todowrite": false,
    "webfetch": false
  },
  "mcp": {
    "urban": {
      "type": "local",
      "command": ["python", "packages/backend/mcp_bridge.py"],
      "enabled": true,
      "environment": {
        "CURSOR_URBAN_DB": "{env:CURSOR_URBAN_DB}",
        "BRIDGE_URL": "http://localhost:8765"
      }
    }
  }
}

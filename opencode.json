{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3-coder:latest",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:latest": { "name": "Qwen3 Coder" },
        "qwen2.5:14b": { "name": "Qwen 2.5 14B" },
        "llama3.1:8b": { "name": "Llama 3.1 8B" }
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    }
  },
  "tools": {
    "read": false,
    "write": false,
    "bash": false,
    "edit": false,
    "glob": false,
    "grep": false,
    "patch": false,
    "todoread": false,
    "todowrite": false,
    "webfetch": false
  },
  "mcp": {
    "urban": {
      "type": "local",
      "command": ["python", "packages/backend/mcp_bridge.py"],
      "enabled": true,
      "environment": {
        "CURSOR_URBAN_DB": "{env:CURSOR_URBAN_DB}",
        "BRIDGE_URL": "http://localhost:8765"
      }
    }
  }
}
